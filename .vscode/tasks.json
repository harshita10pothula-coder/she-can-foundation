{
    "version": "2.0.0",
    "tasks": [{
        "label": "build",
        "type": "shell",
        "command": "g++",
        "args": ["-g", "${file}", "-o", "${fileDirname}\\${fileBasenameNoExtension}.exe"],
        "group": "build"
    }, {
        "label": "build & run",
        "type": "shell",
        "dependsOn": "build",
        "command": "${fileDirname}\\${fileBasenameNoExtension}.exe",
        "presentation": {
            "clear": true,
            "panel": "new"
        }
    }]
}
